<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UI.ViewModels.HierarchyView">
        <Grid RowDefinitions="Auto,Auto,*">
            <Button Grid.Row="0"
                    HorizontalAlignment="Stretch" 
                    Focusable="False" 
                    Margin="5"
                    CornerRadius="15"
                    Click="OnAddObjectButtonClick" ToolTip.Tip="Add Object">
                <Image Source="../Assets/addObject.png" Height="20"/>
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Cube" Click="OnAddCubePressed"/>
                        <MenuItem Header="Sphere" Click="OnAddSpherePressed"/>
                        <MenuItem Header="Cylinder" Click="OnAddCylinderPressed"/>
                        <MenuItem Header="Cone" Click="OnAddConePressed"/>
                        <MenuItem Header="Torus" Click="OnAddTorusPressed"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <Separator Grid.Row="1"/>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="HierarchyStack"/>
            </ScrollViewer>
        </Grid>
</UserControl>
