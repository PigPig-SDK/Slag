<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="OpenglAvaloniaTest.HierarchyModel">
    <Grid Background="Gray">
        <Expander HorizontalAlignment="Stretch" Focusable="False">
            <Expander.Header>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                    <Button Grid.Column="0" Content="Hide" CornerRadius="0"/>
                    <TextBox Grid.Column="1"
                             x:Name="NameTextbox"
                             Text="SuperLongFuckingName"
                             VerticalAlignment="Center"
                             Watermark="ObjectName" KeyDown="OnNameKeyDown"/>
                </Grid>
            </Expander.Header>
            <!-- Expanded content -->
            <StackPanel>
                <!-- properties here -->
            </StackPanel>
        </Expander>
    </Grid>
</UserControl>
